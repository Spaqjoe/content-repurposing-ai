# Copy to `.env.local` for local Next.js dev.
# Most Cloudflare setup lives in `wrangler.jsonc`, not here.
#
# Required for real AI + D1 locally (macOS 13.5+ or Linux):
#   1. npx wrangler login
#   2. npx wrangler d1 create content-ai-db
#   3. Put the returned database_id in wrangler.jsonc
#   4. npm run db:migrate:local && npm run db:migrate:remote
#
# On unsupported macOS versions, leave this file empty — the app uses mock generation.

# -----------------------------------------------------------------------------
# Local development (optional)
# -----------------------------------------------------------------------------

# Force-skip Cloudflare Workers bindings during `pnpm dev`.
# Useful if workerd fails locally but you still want Next.js dev.
# SKIP_CLOUDFLARE_DEV=1

# Select a Wrangler environment from wrangler.jsonc during local dev.
# NEXT_DEV_WRANGLER_ENV=production

# -----------------------------------------------------------------------------
# Deploy / CI (optional — interactive `wrangler login` works too)
# -----------------------------------------------------------------------------

# Cloudflare account ID (Dashboard → Workers & Pages → Overview → Account ID).
# CLOUDFLARE_ACCOUNT_ID=

# API token with Workers, D1, and Workers AI permissions.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=

# Legacy alias accepted by some Wrangler tooling.
# CF_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Access-protected preview/deploy targets (optional)
# Only needed if your Worker sits behind Cloudflare Access.
# -----------------------------------------------------------------------------

# CLOUDFLARE_ACCESS_CLIENT_ID=
# CLOUDFLARE_ACCESS_CLIENT_SECRET=
